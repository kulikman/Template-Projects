#!/usr/bin/env bash

COMMIT_MSG_FILE=$1

# Skip merge commits.
if grep --quiet --extended-regexp " into |^Merge " "$COMMIT_MSG_FILE"; then
    exit 0
fi

COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

CONVENTIONAL_COMMIT_REGEX='^(feat|fix|docs|style|refactor|test|chore|build|ci|perf|revert)(\([a-zA-Z0-9_.-]+\))?(!)?:[[:space:]].*$'

if ! [[ $COMMIT_MSG =~ $CONVENTIONAL_COMMIT_REGEX ]]; then
    echo "ERROR: Commit message does not follow Conventional Commits format."
    echo
    echo "Expected: <type>(<optional scope>): <description>"
    echo
    echo "Valid types:"
    echo "  feat     — new user-facing capability"
    echo "  fix      — bug fix"
    echo "  docs     — documentation only"
    echo "  style    — formatting, whitespace (no logic change)"
    echo "  refactor — internal cleanup, no behavior change"
    echo "  test     — adding or fixing tests"
    echo "  chore    — tooling, deps, CI"
    echo "  build    — build system changes"
    echo "  ci       — CI/CD changes"
    echo "  perf     — performance improvement"
    echo "  revert   — reverting a previous commit"
    echo
    echo "Examples:"
    echo "  feat(auth): add magic link login"
    echo "  fix(api)!: resolve timeout on large uploads"
    echo "  docs(readme): update installation steps"
    echo
    exit 1
fi

# Run commitlint if available (enforces scope-enum, subject-case, length).
if command -v pnpm &> /dev/null && [ -f "package.json" ]; then
    pnpm exec commitlint --edit "$1"
fi
