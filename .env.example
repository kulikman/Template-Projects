# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in real values.
# All variables are validated by Zod at startup (src/lib/env.ts).
# Production values live in `vercel env` — never commit .env.local.
# ===========================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App (required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Template-SAAS-Projects

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# --- Payments (optional) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@example.com

# --- Cron jobs (set when wiring scheduled routes; min 16 chars) ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Rate limiting (optional — falls back to in-memory) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
