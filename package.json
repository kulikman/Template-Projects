{
  "name": "template-projects",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "init:structure": "bash scripts/init-project-structure.sh",
    "post-clone": "bash scripts/post-clone.sh",
    "dev": "node scripts/remind-rename-if-template.mjs && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:boundaries": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check",
    "knip": "knip",
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/database.ts",
    "seed": "tsx scripts/seed.ts",
    "sfo": "tsx solo-founder-os/cli/sfo.ts",
    "sfo:list": "tsx solo-founder-os/cli/sfo.ts list",
    "sfo:status": "tsx solo-founder-os/cli/sfo.ts status",
    "sfo:validate": "tsx solo-founder-os/cli/sfo.ts validate",
    "sfo:generate": "tsx solo-founder-os/cli/sfo.ts generate",
    "sfo:write-local": "tsx solo-founder-os/cli/sfo.ts write-local",
    "sfo:merge-local": "tsx solo-founder-os/cli/sfo.ts merge-local",
    "sfo:dry-run": "tsx solo-founder-os/cli/sfo.ts dry-run",
    "sfo:snapshot": "tsx solo-founder-os/cli/sfo.ts snapshot",
    "sfo:history": "tsx solo-founder-os/cli/sfo.ts history",
    "git:qp": "git add . && git commit -m \"chore: quick push\" && git push",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.372.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "semantic-release": "^25.0.3",
    "shadcn": "^4.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
